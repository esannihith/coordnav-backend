# All vars below are required at boot (src/config/env.ts throws if missing).

# Postgres connection string. Managed providers (Neon etc.) need sslmode=require.
DATABASE_URL="postgresql://user:password@host:5432/coordnav?sslmode=require"

# Google OAuth web client ID — must match the webClientId the mobile app signs in with,
# since the server verifies ID tokens against this audience only (src/lib/google.ts).
GOOGLE_WEB_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"

# Billed key for the Places proxy (/api/v1/places/*). Restrict it to the server's IP.
GOOGLE_PLACES_API_KEY="AIza..."

# HS256 signing secret for access tokens. Generate: openssl rand -hex 32
JWT_ACCESS_SECRET="change-me"

# Access token lifetime (jsonwebtoken format) and refresh token lifetime in days.
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="60"

PORT="8000"

# Only used by docker-compose's prod profile (Caddy TLS), not by the app itself.
# DOMAIN="coordnav.example.com"
