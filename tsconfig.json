{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./",
    "outDir": "./dist",

    "types": ["node"],

    "strict": true,

    "sourceMap": true,

    "esModuleInterop": true,

    "skipLibCheck": true
  },
  "include": ["./src/**/*", "./generated/*" ]
}